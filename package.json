{
  "name": "@ibrahim-mohammed-47/clkit",
  "version": "1.0.4",
  "description": "A CLI wizard to help teams share the same claude code powers by scaffolding project scope configuration",
  "type": "module",
  "bin": {
    "clkit": "./bin/clkit.js"
  },
  "scripts": {
    "start": "node bin/clkit.js",
    "dev": "node --watch bin/clkit.js",
    "release": "npm version patch && git push --follow-tags",
    "release:minor": "npm version minor && git push --follow-tags",
    "release:major": "npm version major && git push --follow-tags"
  },
  "keywords": [
    "claude",
    "kit",
    "scaffold",
    "cli",
    "agents",
    "skills"
  ],
  "author": "Ibrahim Mohammed",
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^8.4.2",
    "figlet": "^1.11.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "shadcn": "^4.5.0"
  }
}
