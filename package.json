{
  "name": "@ibrahim-mohammed-47/clkit",
  "version": "1.4.0",
  "description": "A CLI wizard to help teams share the same claude code powers by scaffolding project scope configuration",
  "type": "module",
  "bin": {
    "clkit": "./bin/clkit.js"
  },
  "scripts": {
    "start": "node bin/clkit.js",
    "dev": "node --watch bin/clkit.js",
    "test": "vitest run --passWithNoTests"
  },
  "keywords": [
    "claude",
    "kit",
    "scaffold",
    "cli",
    "agents",
    "skills"
  ],
  "repository": {
